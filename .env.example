# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://twigloop:twigloop@localhost:5432/twigloop
REDIS_URL=redis://localhost:6379/0

# ===== NATS =====
NATS_URL=nats://localhost:4222

# ===== Temporal =====
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=twigloop
TEMPORAL_TASK_QUEUE=twigloop-workflows
USE_TEMPORAL_WORKFLOWS=false

# ===== ClickHouse =====
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=twigloop_analytics
CLICKHOUSE_USER=twigloop
CLICKHOUSE_PASSWORD=twigloop

# ===== 鉴权 =====
JWT_SECRET=local-dev-secret-must-be-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== S3 =====
S3_ENDPOINT=http://localhost:9010
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=twigloop

# ===== MCP Server =====
CORE_API_BASE_URL=http://localhost:8000

# ===== AI =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===== 环境 =====
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=DEBUG
